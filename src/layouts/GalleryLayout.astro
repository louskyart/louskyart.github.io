---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { coverImages as images } from '../data/images.js';
import Nav from '../components/Nav.astro';
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lou Sky</title>
    <script is:inline>
      document.addEventListener('contextmenu', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });
      document.addEventListener('dragstart', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });
    </script>
  </head>
  <body>
    <Nav />

    <div class="gallery">
      {images.map((img) => (
        <a href={`/imagem/${img.id}`}>
          <Image src={img.image} alt={img.title} class="gallery-img" />
        </a>
      ))}
    </div>

    <style>
      .gallery {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 2.5rem;
        max-width: 1500px;
        margin: 0 auto;
        padding: 3rem 0;
      }
      .gallery a {
        position: relative;
        text-decoration: none;
        color: inherit;
      }
      .gallery a::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0);
        transition: background 0.3s ease;
        pointer-events: none;
      }
      .gallery a:hover::after {
        background: rgba(255,255,255,0.35);
      }
      .gallery a:hover .gallery-img {
        opacity: 0.75;
      }
      .gallery-img {
        width: 100%;
        box-shadow: 8px 8px 20px rgba(0,0,0,0.08);
        transition: opacity 0.3s ease;
      }
      .gallery a:nth-child(1) { grid-column: 1 / span 7; grid-row: 1; }
      .gallery a:nth-child(2) { grid-column: 8 / span 5; grid-row: 1; }
      .gallery a:nth-child(3) { grid-column: 2 / span 6; grid-row: 2; }
      .gallery a:nth-child(4) { grid-column: 9 / span 4; grid-row: 2; }
      .gallery a:nth-child(5) { grid-column: 1 / span 5; grid-row: 3; }
      .gallery a:nth-child(6) { grid-column: 6 / span 7; grid-row: 3; }
    </style>
  </body>
</html>
